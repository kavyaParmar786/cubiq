# Frontend (Next.js) - prefix with NEXT_PUBLIC_ for client-side access
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# Backend (Node.js/Express)
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cubiqhost

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Pterodactyl API
PTERODACTYL_URL=https://your-panel.example.com
PTERODACTYL_API_KEY=your_pterodactyl_application_api_key

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Cubiq Host <no-reply@cubiqhost.com>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Admin
ADMIN_EMAIL=admin@cubiqhost.com
ADMIN_PASSWORD=Admin@123456
