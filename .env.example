# ============================================================
# CUBIQ HOST v2 — Environment Variables
# Copy to .env.local and fill in your real values
# ============================================================

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Pterodactyl ───────────────────────────────────────────────
PTERODACTYL_URL=https://panel.yourdomain.com
PTERODACTYL_API_KEY=ptla_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PTERODACTYL_CLIENT_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PTERODACTYL_PAPER_EGG_ID=1
PTERODACTYL_VANILLA_EGG_ID=2
PTERODACTYL_FORGE_EGG_ID=3
PTERODACTYL_FABRIC_EGG_ID=4

# ── Email via Resend ──────────────────────────────────────────
# Get from: resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Cubiq Host <noreply@yourdomain.com>

# ── Razorpay ─────────────────────────────────────────────────
# Get from: dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
